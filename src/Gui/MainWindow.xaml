<Window x:Class="SharpForge.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SharpForge"
        Width="1180"
        Height="820"
        MinWidth="960"
        MinHeight="680"
        SourceInitialized="Window_SourceInitialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Visibility="Collapsed">
            <TextBox x:Name="DefinesBox" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" />
            <TextBox x:Name="RootTableBox" Text="SF__" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" />
            <TextBox x:Name="IgnoreClassBox" Text="JASS" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" />
            <TextBox x:Name="LibraryFolderBox" Text="libs" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" />
            <TextBox x:Name="IncludeBox" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" />
        </StackPanel>

        <Grid Grid.Row="0" Margin="20,18,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ListBox x:Name="NavigationList" Grid.Row="0" SelectionChanged="NavigationList_SelectionChanged" BorderThickness="0" Background="Transparent" Margin="0,0,0,18">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBoxItem Content="Map Builder" MinWidth="170" />
                <ListBoxItem Content="JASS Bindings" MinWidth="170" />
                <ListBoxItem Content="Settings" MinWidth="170" />
            </ListBox>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel x:Name="MapBuilderView">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Map path" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                            <ComboBox x:Name="MapPathBox" Grid.Column="1" IsEditable="True" SelectionChanged="MapPathChanged" LostFocus="MapPathLostFocus" KeyUp="MapPathKeyUp" ToolTip="The .w3x file or folder-map that Builder updates and Warcraft launches." />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Content="Open" Click="SelectMapPath" Width="82" />
                                <Button Content="Folder" Click="SelectMapFolder" Width="82" Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <Grid>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Transpiler" Style="{StaticResource CardTitle}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <CheckBox x:Name="EnableTranspilerBox" Content="Enabled" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Checked="PipelineOptionChanged" Unchecked="PipelineOptionChanged" ToolTip="Include the transpiler command in Run." />
                                                <Button Content="Edit" Click="EditTranspiler" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Style="{StaticResource FieldGrid}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="C# project path" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="CSharpPathBox" Grid.Column="1" IsReadOnly="True" TextChanged="CSharpPathChanged" LostFocus="AnyFieldLostFocus" ToolTip="Folder containing the C# sources to transpile." />
                                        </Grid>
                                        <Grid Style="{StaticResource FieldGrid}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Output Lua" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="TranspileOutputBox" Grid.Column="1" IsReadOnly="True" TextChanged="TranspileOutputChanged" LostFocus="AnyFieldLostFocus" ToolTip="Lua file written by sf-transpile." />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,46,0,0">
                                            <Button Content="Init" Click="RunTranspileInit" />
                                            <Button Content="Check" Click="RunTranspileCheck" Margin="8,0,0,0" />
                                            <Button Content="Transpile" Click="RunTranspile" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border x:Name="TranspilerBusyOverlay" Visibility="Collapsed" Background="#CCFFFFFF" CornerRadius="8">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="180">
                                            <ProgressBar x:Name="TranspilerProgress" IsIndeterminate="True" Height="5" />
                                            <TextBlock x:Name="TranspilerStatusText" Text="Executing transpiler..." HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <Grid>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Builder" Style="{StaticResource CardTitle}" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <CheckBox x:Name="EnableBuilderBox" Content="Enabled" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Checked="PipelineOptionChanged" Unchecked="PipelineOptionChanged" ToolTip="Include the builder command in Run." />
                                                <Button Content="Edit" Click="EditBuilder" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Style="{StaticResource FieldGrid}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Main Lua file" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="MainLuaBox" Grid.Column="1" IsReadOnly="True" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Entry Lua file for sf-build." />
                                        </Grid>
                                        <Grid Style="{StaticResource FieldGrid}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Output" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="BuilderOutputBox" Grid.Column="1" IsReadOnly="True" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Build target. Defaults to the selected map path." />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,46,0,0">
                                            <Button Content="Build" Click="RunBuild" Style="{StaticResource PrimaryButton}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border x:Name="BuilderBusyOverlay" Visibility="Collapsed" Background="#CCFFFFFF" CornerRadius="8">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="180">
                                            <ProgressBar x:Name="BuilderProgress" IsIndeterminate="True" Height="5" />
                                            <TextBlock x:Name="BuilderStatusText" Text="Executing builder..." HorizontalAlignment="Center" Margin="0,12,0,0" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <TextBlock Text="Run" Style="{StaticResource CardTitle}" />
                                </Grid>
                                <TextBox x:Name="RunCommandsBox" MinHeight="150" AcceptsReturn="True" TextWrapping="Wrap" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" TextChanged="RunCommandsChanged" LostFocus="AnyFieldLostFocus" ToolTip="Commands executed by Run, one per line. Any field change regenerates this preview." />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button Content="Run" Click="RunWarcraft" Style="{StaticResource PrimaryButton}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="JassGenView" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="JASS Bindings" Style="{StaticResource CardTitle}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Edit" Click="EditJassGen" />
                                        <Button Content="Generate" Click="RunJassGen" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Grid Style="{StaticResource FieldGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="JASS source folder" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="JassInputBox" Grid.Column="1" IsReadOnly="True" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Folder containing common.j and/or blizzard.j sources for sf-jassgen." />
                                </Grid>
                                <Grid Style="{StaticResource FieldGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Output folder" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="JassOutputBox" Grid.Column="1" IsReadOnly="True" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Folder where generated C# JASS binding stubs are written." />
                                </Grid>
                                <Grid Style="{StaticResource FieldGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Host class" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="JassHostClassBox" Grid.Column="1" IsReadOnly="True" Text="JASS" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Static partial class name that hosts generated JASS natives and globals." />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="SettingsView" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Warcraft 3" Style="{StaticResource CardTitle}" />
                                <Grid Style="{StaticResource FieldGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="112" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Install path" Style="{StaticResource FieldLabel}" ToolTip="Folder containing _retail_\x86_64\Warcraft III.exe." />
                                    <TextBox x:Name="WarcraftPathBox" Grid.Column="1" TextChanged="AnyTextChanged" LostFocus="AnyFieldLostFocus" ToolTip="Folder containing _retail_\x86_64\Warcraft III.exe." />
                                    <Button Grid.Column="2" Content="Browse" Click="SelectWarcraftPath" Margin="8,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
